{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/app.html",
      "headers": {
        "cache-control": "no-store, no-cache, must-revalidate, proxy-revalidate"
      },
      "dest": "/app.html"
    },
    {
      "src": "/js/core/(.*)",
      "headers": {
        "cache-control": "no-store, no-cache, must-revalidate"
      },
      "dest": "/js/core/$1"
    },
    {
      "src": "/js/pages/(.*)",
      "headers": {
        "cache-control": "no-store, no-cache, must-revalidate"
      },
      "dest": "/js/pages/$1"
    },
    {
      "src": "/js/components/(.*)",
      "headers": {
        "cache-control": "no-store, no-cache, must-revalidate"
      },
      "dest": "/js/components/$1"
    }
  ]
}