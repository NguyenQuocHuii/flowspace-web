{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=flowspace;Username=postgres;Password=postgres",
    "Redis": "YOUR_PRODUCTION_REDIS_SERVER:6379"
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "FlowSpaceProd",
    "Audience": "FlowSpaceProdUsers",
    "ExpiryMinutes": 15
  },
  "CorsSettings": {
    "AllowedOrigins": []
  },
  "AllowedHosts": "*"
}