{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_PRODUCTION_DB_SERVER;Database=FlowSpaceDb;User Id=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;",
    "Redis": "YOUR_PRODUCTION_REDIS_SERVER:6379"
  },
  "JwtSettings": {
    "Secret": "YOUR_PRODUCTION_SECURE_JWT_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "FlowSpaceProd",
    "Audience": "FlowSpaceProdUsers",
    "ExpiryMinutes": 15
  },
  "CorsSettings": {
    "AllowedOrigins": []
  },
  "AllowedHosts": "*"
}
